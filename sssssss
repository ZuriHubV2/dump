-- Draggable logic (unchanged)
local dragging, dragInput, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Minimize toggle
local minimized = false
MinimizeButton.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        MainFrame.Size = UDim2.new(0, 340, 0, 45)
        ItemInput.Visible = false
        SpawnButton.Visible = false
        CreditsLabel.Visible = false
        NotesLabel.Visible = false
        MinimizeButton.Text = "+"
    else
        MainFrame.Size = UDim2.new(0, 340, 0, 240)
        ItemInput.Visible = true
        SpawnButton.Visible = true
        CreditsLabel.Visible = true
        NotesLabel.Visible = true
        MinimizeButton.Text = "−"
    end
end)

-- Hover effects
local function hover(button, toColor, fromColor)
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = toColor}):Play()
    end)
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {BackgroundColor3 = fromColor}):Play()
    end)
end

hover(SpawnButton, Color3.fromRGB(50, 130, 255), Color3.fromRGB(30, 110, 255))
hover(MinimizeButton, Color3.fromRGB(220, 70, 70), Color3.fromRGB(200, 50, 50))

-- Spawn logic (unchanged)
SpawnButton.MouseButton1Click:Connect(function()
    local itemName = ItemInput.Text:match("^%s*(.-)%s*$")
    
    if itemName == "" or not itemName then
        local notif = Instance.new("TextLabel")
        notif.Size = UDim2.new(0, 220, 0, 45)
        notif.Position = UDim2.new(0.5, -110, 0.15, 0)
        notif.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        notif.Text = "Enter an item name!"
        notif.TextColor3 = Color3.new(1,1,1)
        notif.Font = Enum.Font.GothamBold
        notif.TextSize = 17
        notif.Parent = ScreenGui
        local nc = Instance.new("UICorner", notif); nc.CornerRadius = UDim.new(0,10)
        
        wait(2.8)
        notif:Destroy()
        return
    end
    
    pcall(function()
        local remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
        if remotes then
            local shop = remotes:FindFirstChild("Shop")
            if shop then
                local box = shop:FindFirstChild("BoxController") or shop:FindFirstChildWhichIsA("RemoteEvent")
                if box and box:IsA("RemoteEvent") then
                    box:FireServer("KnifeBox4", itemName)
                end
            end
        end
    end)
    
    pcall(function()
        local ProfileData = require(ReplicatedStorage.Modules.ProfileData)
        local Weapons = ProfileData.Weapons.Owned
        Weapons[itemName] = (Weapons[itemName] or 0) + 1
        
        if LocalPlayer.Character then
            LocalPlayer.Character:BreakJoints()
        end
    end)
    
    SpawnButton.Text = "Attempted: " .. itemName
    wait(2.5)
    SpawnButton.Text = "Spawn Item"
end)

print("[Zuri MM2 Spawner]")
